local ESPObjects = {}

local function MakeESPForPlayer(player)
    if ESPObjects[player] then return end
    local lines = {}
    for i = 1, 4 do
        local l        = Drawing.new("Line")
        l.Thickness    = 1.5
        l.Color        = Color3.fromRGB(255, 60, 60)
        l.Transparency = 1
        l.Visible      = false
        lines[i]       = l
    end
    local nameTag        = Drawing.new("Text")
    nameTag.Size         = 13
    nameTag.Color        = Color3.fromRGB(255, 255, 255)
    nameTag.Outline      = true
    nameTag.OutlineColor = Color3.fromRGB(0, 0, 0)
    nameTag.Center       = true
    nameTag.Visible      = false
    nameTag.Text         = player.Name
    ESPObjects[player]   = { lines = lines, name = nameTag }
end

local function RemoveESPForPlayer(player)
    if not ESPObjects[player] then return end
    for _, l in ipairs(ESPObjects[player].lines) do l:Remove() end
    ESPObjects[player].name:Remove()
    ESPObjects[player] = nil
end

local function SetESPVisible(player, visible)
    if not ESPObjects[player] then return end
    for _, l in ipairs(ESPObjects[player].lines) do l.Visible = visible end
    ESPObjects[player].name.Visible = visible
end

local function UpdateESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        if not Settings.ESP then
            if ESPObjects[player] then SetESPVisible(player, false) end
            continue
        end

        local char = player.Character
        if not char then
            if ESPObjects[player] then SetESPVisible(player, false) end
            continue
        end

        local hrp  = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        if not hrp or not head then
            if ESPObjects[player] then SetESPVisible(player, false) end
            continue
        end

        MakeESPForPlayer(player)

        local rootScreen, rootOnScreen = Camera:WorldToScreenPoint(hrp.Position)
        local headScreen, headOnScreen = Camera:WorldToScreenPoint(head.Position)

        if not rootOnScreen or not headOnScreen then
            SetESPVisible(player, false)
            continue
        end

        local top    = headScreen.Y - 10
        local bottom = rootScreen.Y + 14
        local height = bottom - top
        local width  = height * 0.5
        local cx     = rootScreen.X
        local left   = cx - width / 2
        local right  = cx + width / 2

        local esp = ESPObjects[player]
        local visible  = IsVisible(hrp)
        local boxColor = visible and Color3.fromRGB(255, 60, 60) or Color3.fromRGB(255, 160, 0)

        esp.lines[1].From  = Vector2.new(left,  top)
        esp.lines[1].To    = Vector2.new(right, top)
        esp.lines[1].Color = boxColor
        esp.lines[2].From  = Vector2.new(left,  bottom)
        esp.lines[2].To    = Vector2.new(right, bottom)
        esp.lines[2].Color = boxColor
        esp.lines[3].From  = Vector2.new(left, top)
        esp.lines[3].To    = Vector2.new(left, bottom)
        esp.lines[3].Color = boxColor
        esp.lines[4].From  = Vector2.new(right, top)
        esp.lines[4].To    = Vector2.new(right, bottom)
        esp.lines[4].Color = boxColor

        esp.name.Position = Vector2.new(cx, top - 16)
        esp.name.Text     = player.Name

        SetESPVisible(player, true)
    end
end

