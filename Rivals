local function GetClosestToCursor()
    local closestPlayer = nil
    local shortestDist  = math.huge
    local center        = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer
            and player.Character
            and player.Character:FindFirstChild(Settings.AimPart)
            and not (LocalPlayer.Team and player.Team == LocalPlayer.Team)
        then
            local part = player.Character[Settings.AimPart]
            local screenPos, onScreen = Camera:WorldToScreenPoint(part.Position)
            if onScreen then
                local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                if dist <= Settings.CircleRadius and dist < shortestDist and IsVisible(part) then
                    closestPlayer = player
                    shortestDist  = dist
                end
            end
        end
    end
    return closestPlayer
end

RunService.RenderStepped:Connect(function()
    UpdateESP()

    if Settings.Enabled then
        FOVCircle.Visible  = true
        FOVCircle.Radius   = Settings.CircleRadius
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

        if Settings.CurrentTarget then
            local char = Settings.CurrentTarget.Character
            if not char
                or not char:FindFirstChild(Settings.AimPart)
                or not IsVisible(char[Settings.AimPart])
            then
                Settings.CurrentTarget = nil
            end
        end

        if not Settings.CurrentTarget then
            Settings.CurrentTarget = GetClosestToCursor()
        end

        if Settings.CurrentTarget then
            local char = Settings.CurrentTarget.Character
            if char and char:FindFirstChild(Settings.AimPart) then
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, char[Settings.AimPart].Position)
            end
        end
    else
        FOVCircle.Visible = false
    end
end)

