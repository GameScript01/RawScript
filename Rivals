local function MakeButton(posY, label, accent)
    accent = accent or Color3.fromRGB(0, 210, 255)
    local Btn                = Instance.new("TextButton")
    Btn.Parent               = MainFrame
    Btn.Position             = UDim2.new(0, 12, 0, posY)
    Btn.Size                 = UDim2.new(1, -24, 0, 32)
    Btn.BackgroundColor3     = Color3.fromRGB(16, 16, 28)
    Btn.BorderSizePixel      = 0
    Btn.Text                 = ""
    Btn.AutoButtonColor      = false
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)

    local Stroke             = Instance.new("UIStroke")
    Stroke.Color             = accent
    Stroke.Thickness         = 1
    Stroke.Transparency      = 0.6
    Stroke.Parent            = Btn

    local Lbl                    = Instance.new("TextLabel")
    Lbl.Parent                   = Btn
    Lbl.Size                     = UDim2.new(1, 0, 1, 0)
    Lbl.BackgroundTransparency   = 1
    Lbl.Text                     = label
    Lbl.TextColor3               = Color3.fromRGB(200, 230, 255)
    Lbl.Font                     = Enum.Font.GothamSemibold
    Lbl.TextSize                 = 11

    Btn.MouseEnter:Connect(function()
        TweenService:Create(Btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(0, 40, 60)}):Play()
        Stroke.Transparency = 0
    end)
    Btn.MouseLeave:Connect(function()
        TweenService:Create(Btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(16, 16, 28)}):Play()
        Stroke.Transparency = 0.6
    end)

    return Btn, Lbl, Stroke
end

